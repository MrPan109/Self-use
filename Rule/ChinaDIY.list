# China Apps
USER-AGENT,MicroMessenger Client
USER-AGENT,WeChat*
USER-AGENT,MApi* // Dianping
# Ali
DOMAIN-KEYWORD,alipay
DOMAIN-KEYWORD,taobao
DOMAIN-KEYWORD,alicdn
DOMAIN-KEYWORD,aliyun
DOMAIN-KEYWORD,.tmall.
IP-CIDR,198.11.188.0/25,no-resolve
IP-CIDR,198.11.136.0/24,no-resolve
USER-AGENT,%E6%89%8B%E6%9C%BA%E6%B7%98%E5%AE%9D*
# AppleCN
DOMAIN,gs-loc-cn.apple.com
DOMAIN,appleintelligencefeedback.care.apple.com
DOMAIN-SUFFIX,gspe19-cn-ssl.ls.apple.com
DOMAIN-SUFFIX,cn-ssl.ls.apple.com
DOMAIN-SUFFIX,cn.ls.apple.com
DOMAIN-SUFFIX,cn.apple.com
# AppleCDN
# --- Apple 静态资源 (精确匹配编号与特定前缀) ---
DOMAIN-WILDCARD,a[1-5].mzstatic.com
DOMAIN-WILDCARD,is[1-5].mzstatic.com
DOMAIN-WILDCARD,is[1-5]-ssl.mzstatic.com
DOMAIN,s.mzstatic.com
DOMAIN,apps.mzstatic.com
# --- 地图与位置服务 (锁定 apple-mapkit 与 gs-loc) ---
DOMAIN-WILDCARD,cdn*.apple-mapkit.com
DOMAIN-WILDCARD,cdn-cn*.apple-mapkit.com
DOMAIN-WILDCARD,gs-loc*.apple.com
DOMAIN,cdn.apple-mapkit.com
# --- 软件更新与分发 (锁定 aaplimg 及更新组件) ---
DOMAIN-SUFFIX,g.aaplimg.com
DOMAIN-SUFFIX,v.aaplimg.com
DOMAIN-SUFFIX,cdn-apple.com
DOMAIN-KEYWORD,swcdn
DOMAIN-KEYWORD,swdist
DOMAIN-KEYWORD,swscan
DOMAIN-KEYWORD,swcatalog
DOMAIN-KEYWORD,mesu-cdn
# --- 推送、初始化与设备管理 (精确匹配 init 与 pod 模式) ---
DOMAIN-WILDCARD,init-*.apple.com
DOMAIN-WILDCARD,init-*.push.apple.com
DOMAIN-WILDCARD,*-pod*-smp-device.apple.com
DOMAIN,smp-device-content.apple.com
DOMAIN-SUFFIX,push-apple.com.akadns.net
# --- 位置服务子域 (精确匹配 ls 业务簇) ---
# 覆盖 gsp10, gsp12, gsp4, gspe19, gspe79 等及其 TLS 版本
URL-REGEX,^http(s)?:\/\/(gsp|gspe)[0-9a-z-]*\.ls\.apple\.com
DOMAIN-SUFFIX,ls-apple.com.akadns.net
# --- 证书、天气与 Siri (精确关键词锁定) ---
DOMAIN,ocsp.apple.com
DOMAIN,ocsp2.apple.com
DOMAIN,certs.apple.com
DOMAIN,crl.apple.com
DOMAIN,valid.apple.com
DOMAIN-SUFFIX,lb.apple.com.akadns.net
DOMAIN-WILDCARD,weather-*.apple.com
DOMAIN,weatherkit.apple.com
DOMAIN-KEYWORD,siri.apple.com
# --- 复杂重定向链与特定路径 (使用正则精确压减) ---
# 1. 覆盖 cl1-cl5 相关(包含 .cn, -cdn, 及 origin-apple 跳转)
URL-REGEX,^http(s)?:\/\/cl[1-5](-cn)?(-cdn)?(\.apple\.com|\.origin-apple\.com\.akadns\.net)
# 2. 覆盖 edgekey.net 相关的全球重定向
URL-REGEX,^http(s)?:\/\/.*\.apple\.com\.edgekey\.net
# --- 列表内其余无规律独立域名 (DOMAIN 精确匹配) ---
